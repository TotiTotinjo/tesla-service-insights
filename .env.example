# Get a key at https://console.x.ai
XAI_API_KEY=xai-your-key-here

# General / fallback model
XAI_MODEL=grok-4.5

# Cheaper model for invoice extraction (strongly recommended)
XAI_EXTRACT_MODEL=grok-4-1-fast-non-reasoning

# Cap invoice text sent to the model (chars). Default 18000.
# MAX_INVOICE_CHARS=18000

# Cap completion tokens per extract call. Default 3500 (multi-visit JSON).
# XAI_MAX_TOKENS=3500

# --- Early beta cost controls (defaults shown) ---
# Analyses that call Grok (duplicates do not count)
BETA_MAX_ANALYZES_PER_IP_PER_DAY=3
BETA_MAX_ANALYZES_GLOBAL_PER_DAY=40
BETA_MAX_PUBLISHES_PER_IP_PER_DAY=5
# Local only: set true to disable caps while developing
# BETA_RATE_LIMIT_DISABLED=true
